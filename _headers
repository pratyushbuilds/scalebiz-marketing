# ── Security headers (all routes) ──────────────────────
# CSP allows exactly what the site uses: self-hosted CSS/JS/fonts/images,
# GSAP/ScrollTrigger/Matter from cdnjs, and form POSTs to Supabase.
# 'unsafe-inline' is required for the inlined critical CSS and the one
# onload="this.media='all'" handler on the deferred footer stylesheet.
# If you ever add a new third-party (analytics, embed, CDN), add its
# origin to the matching directive or the browser will block it.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; connect-src 'self' https://*.supabase.co; form-action 'self'; upgrade-insecure-requests

# ── Long-cache immutable assets ────────────────────────
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
